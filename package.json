{
  "name": "societyer",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first desktop and web tools for society records, documents, and operations.",
  "author": "Societyer",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:k8s": "VITE_CONVEX_URL=${VITE_CONVEX_URL:-http://societyer.k8s.home:3220} VITE_AUTH_MODE=${VITE_AUTH_MODE:-none} vite --host 127.0.0.1",
    "dev:full": "concurrently -k \"npm run auth:server\" \"npm run dev\"",
    "build": "npm run convex:typecheck && tsc -b && vite build",
    "desktop:typecheck": "tsc -p tsconfig.electron.json --noEmit",
    "desktop:build": "tsc -p tsconfig.electron.json && VITE_RUNTIME_MODE=electron-local VITE_DOCUMENT_STORAGE_PROVIDER=local-filesystem VITE_BASE_PATH=./ vite build",
    "desktop:dev": "concurrently -k \"VITE_RUNTIME_MODE=electron-local VITE_DOCUMENT_STORAGE_PROVIDER=local-filesystem vite --host 127.0.0.1 --port 55173 --strictPort\" \"wait-on http://127.0.0.1:55173 && npm run desktop:build:main && VITE_DEV_SERVER_URL=http://127.0.0.1:55173 electron .\"",
    "desktop:build:main": "tsc -p tsconfig.electron.json",
    "desktop:package": "npm run desktop:build && electron-builder --mac --config electron-builder.json",
    "desktop:smoke": "npm run desktop:build && node scripts/smoke-desktop.mjs",
    "build:pages": "npm run convex:typecheck && tsc -b && VITE_STABLE_ASSET_NAMES=1 vite build && node scripts/prepare-pages.mjs",
    "preview": "vite preview",
    "convex": "convex dev",
    "convex:seed": "node scripts/convex-maintenance.mjs seed:run",
    "convex:reset": "node scripts/convex-maintenance.mjs seed:reset",
    "convex:metadata": "node scripts/convex-maintenance.mjs seedRecordTableMetadata:run",
    "convex:codegen": "npx convex codegen",
    "convex:deploy:k8s": "./scripts/deploy-convex-to-k8s.sh",
    "convex:typecheck": "tsc -p convex/tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:convex": "eslint convex",
    "grant-sources:generate": "node scripts/generate-grant-source-library.mjs",
    "grant-sources:validate": "node scripts/validate-grant-source-library.mjs",
    "templates:json": "tsx scripts/generate-starter-template-json.ts",
    "templates:exports": "tsx scripts/render-starter-template-documents.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f backend",
    "docker:connectors": "docker compose --profile connectors up -d connector-runner blitzbrowser blitzbrowser-dashboard",
    "docker:connectors:logs": "docker compose logs -f connector-runner blitzbrowser",
    "docker:admin-key": "./scripts/convex-admin-key.sh",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d --build",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "rustfs:setup": "./scripts/setup-rustfs.sh",
    "connector-runner:typecheck": "npm --prefix services/connector-runner run typecheck",
    "auth:server": "tsx server/auth-server.ts",
    "setup:ote-keycard": "node scripts/setup-ote-keycard-workflow.mjs",
    "test:smoke": "npx playwright test",
    "test:api-contract": "tsx scripts/check-api-contract.ts",
    "test:accounting-core": "tsx scripts/check-accounting-core.ts",
    "test:dashboard-compliance": "tsx scripts/check-dashboard-compliance-rules.ts",
    "test:jurisdiction-guides": "tsx scripts/validate-jurisdiction-guide-packs.ts && tsx scripts/check-jurisdiction-guide-tracks.ts",
    "test:create-workspace-onboarding": "tsx scripts/check-create-workspace-onboarding.ts",
    "test:org-details": "tsx scripts/check-org-detail-smoke.ts",
    "test:pdf-ingestion": "tsx scripts/check-pdf-table-normalization.ts",
    "test:exports": "tsx scripts/check-export-coverage.ts",
    "test:exports:db": "tsx scripts/validate-export-database.ts",
    "test:record-table-utils": "tsx scripts/check-record-table-utils.ts",
    "test:ai-agent-contract": "tsx scripts/check-ai-agent-contract.ts",
    "test:csv-import-utils": "tsx scripts/check-csv-and-import-utils.ts",
    "test:integration-staging": "tsx scripts/check-integration-staging-bundles.ts",
    "export:workspace:files": "tsx scripts/export-workspace-with-files.ts",
    "backup:runtime": "./scripts/backup-runtime-data.sh"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.63",
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@milkdown/core": "^7.21.1",
    "@milkdown/crepe": "^7.21.2",
    "@milkdown/ctx": "^7.21.1",
    "@milkdown/kit": "^7.21.2",
    "@milkdown/plugin-clipboard": "^7.21.1",
    "@milkdown/plugin-history": "^7.21.1",
    "@milkdown/plugin-listener": "^7.21.1",
    "@milkdown/preset-commonmark": "^7.21.1",
    "@milkdown/preset-gfm": "^7.21.1",
    "@milkdown/prose": "^7.21.1",
    "@milkdown/react": "^7.21.1",
    "@milkdown/transformer": "^7.21.1",
    "@milkdown/utils": "^7.21.1",
    "@novnc/novnc": "^1.5.0",
    "@types/express": "^5.0.6",
    "@types/qrcode": "^1.5.6",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.177",
    "better-auth": "^1.6.3",
    "bwip-js": "^4.10.1",
    "concurrently": "^9.2.1",
    "convex": "^1.17.4",
    "date-fns": "^3.6.0",
    "dexie": "^4.4.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fuse.js": "^7.3.0",
    "i18next": "^23.16.5",
    "lucide-react": "^0.469.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "react-virtuoso": "^4.18.5",
    "react-zoom-pan-pinch": "^4.0.3",
    "remark-gfm": "^4.0.1",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.21.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "app.societyer.desktop",
    "productName": "Societyer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.business"
    }
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^2.0.0",
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "sass": "^1.99.0",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^5.4.11",
    "wait-on": "^9.0.10"
  }
}
