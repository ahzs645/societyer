{
  "name": "societyer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently -k \"npm run auth:server\" \"npm run dev\"",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build && node scripts/prepare-pages.mjs",
    "preview": "vite preview",
    "convex": "convex dev",
    "convex:seed": "convex run seed:run",
    "convex:reset": "convex run seed:reset",
    "convex:codegen": "npx convex codegen",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f backend",
    "docker:admin-key": "./scripts/convex-admin-key.sh",
    "auth:server": "tsx server/auth-server.ts"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "better-auth": "^1.6.3",
    "concurrently": "^9.2.1",
    "convex": "^1.17.4",
    "date-fns": "^3.6.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "i18next": "^23.16.5",
    "lucide-react": "^0.469.0",
    "react-i18next": "^15.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "sass": "^1.99.0",
    "typescript": "~5.6.3",
    "vite": "^5.4.11"
  }
}
