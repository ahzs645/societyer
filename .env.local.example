# ---------------------------------------------------------------------------
# Self-hosted Convex via the bundled docker-compose.yml (recommended)
# ---------------------------------------------------------------------------
# 1. docker compose up -d
# 2. ./scripts/convex-admin-key.sh    # paste the printed key below
# 3. npx convex dev                   # pushes schema + functions
# 4. npm run dev

CONVEX_SELF_HOSTED_URL="http://127.0.0.1:3220"
CONVEX_SELF_HOSTED_ADMIN_KEY=""
VITE_CONVEX_URL="http://127.0.0.1:3220"

# ---------------------------------------------------------------------------
# Auth mode
# ---------------------------------------------------------------------------
# `none` keeps the current no-auth workflow for local/demo use.
# `better-auth` enables the Better Auth sidecar and login flow.
AUTH_MODE="none"
VITE_AUTH_MODE="none"

# Better Auth sidecar settings (only used when *_AUTH_MODE is better-auth)
AUTH_SERVER_PORT="8787"
BETTER_AUTH_BASE_URL="http://127.0.0.1:5173"
VITE_AUTH_BASE_URL="http://127.0.0.1:5173"
BETTER_AUTH_SECRET="change-me-before-production"
AUTH_DB_PATH="./data/auth.sqlite"

# ---------------------------------------------------------------------------
# Optional live providers
# ---------------------------------------------------------------------------
# App/public URLs used by Stripe checkout and public transparency links.
APP_BASE_URL="http://127.0.0.1:5173"

# Email delivery via Resend.
# RESEND_API_KEY="re_xxx"
# RESEND_FROM_EMAIL="Societyer <noreply@example.com>"
# RESEND_WEBHOOK_SECRET=""

# Membership billing via Stripe Checkout + webhook.
# STRIPE_SECRET_KEY="sk_live_xxx"
# STRIPE_WEBHOOK_SECRET="whsec_xxx"
# STRIPE_SUCCESS_URL="http://127.0.0.1:5173/#/app/membership?checkout=success"
# STRIPE_CANCEL_URL="http://127.0.0.1:5173/#/app/membership?checkout=cancel"

# Accounting sync via Wave GraphQL.
# WAVE_ACCESS_TOKEN="wave_xxx"
# WAVE_BUSINESS_ID="business_xxx"
# WAVE_CLIENT_ID="wave_client_xxx"
# WAVE_GRAPHQL_ENDPOINT="https://gql.waveapps.com/graphql/public"

# SMS delivery + callbacks via Twilio.
# TWILIO_ACCOUNT_SID="ACxxxx"
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER="+16045551234"
# TWILIO_MESSAGING_SERVICE_SID=""
# TWILIO_STATUS_CALLBACK_URL="http://127.0.0.1:3220/communications/webhooks/twilio"

# RustFS / S3-compatible object storage for signed uploads/downloads.
# RUSTFS_ENDPOINT="https://storage.example.com"
# RUSTFS_BUCKET="societyer"
# RUSTFS_REGION="us-east-1"
# RUSTFS_ACCESS_KEY=""
# RUSTFS_SECRET_KEY=""
# RUSTFS_SESSION_TOKEN=""
# RUSTFS_SERVICE="s3"

# Live meeting-minute generation.
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."

# BC Criminal Records Review Program organization launch URL.
# BC_CRRP_ORG_PORTAL_URL="https://justice.gov.bc.ca/eCRC/"

# Optional: pin the instance secret used by the backend container so it stays
# stable across `docker compose down -v`. Any 64-char hex string works.
# CONVEX_INSTANCE_SECRET="$(openssl rand -hex 32)"

# ---------------------------------------------------------------------------
# Hosted Convex (alternative — `npx convex dev` will populate VITE_CONVEX_URL)
# ---------------------------------------------------------------------------
# VITE_CONVEX_URL="https://<your-deployment>.convex.cloud"
